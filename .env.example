# Local dev: use your local Postgres or a Supabase pooled Postgres URL.
# Production on Render Free: use the Supabase Session pooler string, for example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
PORT=4000
# Production example: https://your-service-name.onrender.com
CLIENT_ORIGIN=http://localhost:5173
# Production example: https://your-service-name.onrender.com
APP_BASE_URL=http://localhost:4000
SESSION_SECRET=change-me
EMAIL_MODE=demo
RESEND_API_KEY=
RESEND_FROM_EMAIL=Axora <onboarding@resend.dev>
SUPPORT_EMAIL=sales@axora.app
