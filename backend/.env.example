NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_APP_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axora
REDIS_URL=redis://localhost:6379
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=
DEV_AUTH_BYPASS=true
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=auto
S3_BUCKET=axora-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/connections/youtube/callback
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:4000/connections/instagram/callback
INSTAGRAM_AUTH_URL=https://www.instagram.com/oauth/authorize
INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_LONG_LIVED_TOKEN_URL=https://graph.instagram.com/access_token
INSTAGRAM_ME_URL=https://graph.instagram.com/me
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/connections/tiktok/callback
TIKTOK_AUTH_URL=https://www.tiktok.com/v2/auth/authorize/
TIKTOK_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MAX_VIDEO_BYTES=524288000
MAX_VIDEO_DURATION_SECONDS=600
WORKSPACE_TIMEZONE=Asia/Calcutta
DEFAULT_WEEKLY_REPORT_HOUR=9
YOUTUBE_DAILY_QUOTA_LIMIT=10000
YOUTUBE_UPLOAD_RESERVATION_UNITS=150
YOUTUBE_QUOTA_SAFETY_BUFFER=2000
YOUTUBE_ALLOW_MOCK=false
